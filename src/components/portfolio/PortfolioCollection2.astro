---
import { getPermalink } from '~/utils/permalinks';
import { getEntry } from 'astro:content';

import PortfolioFilter from '~/components/portfolio/filter/PortfolioFilter2.astro';
import Item from './ListItem.astro';
import RedCheckbox from '~/components/common/RedCheckbox.astro';

const { list } = Astro.props;

const items = [];
for (var idx in list) {
  var item = await getEntry('portfolio', list[idx]);
  if (!item) console.error(`Cannot find portfolio item with name ${list[idx]}`);
  const entry = JSON.parse(JSON.stringify(item));
  entry.data.index = idx;
  entry.data.href = `/portfolio/${list[idx]}`;
  if (entry.data.publishYear) {
    entry.data.tags.push(entry.data.publishYear.toString());
  }
  items.push(entry);
}

---
<div class="portfolio-collection text-left pb-4 md:pb-6 max-w-7xl mx-auto justify-center">
<PortfolioFilter />
<ul class="portfolio-collection flex md:grid md:grid-flow-row-dense md:grid-cols-portfolio-md md:max-w-[640px] lg:grid-cols-portfolio-lg lg:max-w-[960px] xl:grid-cols-portfolio xl:max-w-full flex-wrap justify-start list-none">
  {
    items.map((item, idx) => (
      <li class:list={["mb-6", (item.data.doubleSize ? "w-80 md:w-[640px] md:col-span-2" : "w-80"), item.data.tags?.map((tag) => ('fltr-'+tag)).join(' ')]} id={'portfolio-card-'+idx}>
        <Item post={item.data} body={item.body} mode={item.data.doubleSize ? 'double' : 'single'}/>
      </li>
    ))
  }
</ul>
</div>
