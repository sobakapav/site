---
import { twMerge } from 'tailwind-merge';

import ItemGrid from '~/components/ui/ItemGrid.astro';

import './IndustryColumnGrid.less';

// Accepted "classes" fields:
// container - for grid
// cell - for single cell in grid
// title - for title
// description - for subtitle
// mode - 'foldOnMobile' to fold cards on mobiles
const { 
  cards, 
  columns = 3,
  classes,
  mode,
} = Astro.props; 

const items = cards.map(item => ({
  title: item.title, 
  description: item.text, 
  details: item.details, 
  relatedPages: item.relatedPages,
  link: item.link,
  classes: {panel: 'cell-' + (item.cardColor || 'default')}
}));

---

<three-column>
  <ItemGrid
    columns={columns}
    items={items}
    mode={mode}
    classes={{
      container: twMerge('gap-2 gap-y-2 md:gap-y-2 features-hex', classes?.container),
      panel: 'max-w-full flex p-0',
      button: twMerge('w-full flex p-10', classes?.cell),
      title: twMerge('text-3xl font-heading leading-none mb-4', classes?.title),
      description: twMerge('', classes?.description),
    }}
    />
</three-column>
