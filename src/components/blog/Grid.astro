---
import Item from '~/components/blog/ListItem.astro';
import type { Post } from '~/types';
import { twMerge } from "tailwind-merge";

export interface Props {
  posts: Array<Post>;
}

const { posts, hideFields, classes={} } = Astro.props;
---

<div class="flex flex-wrap justify-normal lg:justify-between gap-4">
  {posts.map((post) => (
    <li class={twMerge("mb-12 md:mb-20 w-[288px]", classes.gridCell)}>
      <Item post={post} hideFields={hideFields} />
    </li>
  ))}
</div>
