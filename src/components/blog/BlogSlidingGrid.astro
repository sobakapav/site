---
import GenericSlidingGrid from '~/components/common/GenericSlidingGrid.astro';
import Item from '~/components/blog/ListItem.astro';
import { findPostsByIds } from '~/utils/blog';

const { posts, hideFields = {} } = Astro.props;

const allPosts = await findPostsByIds(posts);

---
<GenericSlidingGrid
  items={allPosts}
  hideFields={hideFields}
  Item={Item}
  isBlog={true} />
