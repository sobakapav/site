---
import Layout from '~/layouts/PageLayout.astro';

import Hero2 from '~/components/widgets/Hero2.astro';
import Hund2 from '~/components/widgets/Hund2.astro';
import Hund3 from '~/components/widgets/Hund3.astro';
import Hund4 from '~/components/widgets/Hund4.astro';
import Bread from '~/components/widgets/Bread.astro';
import Image from '~/components/common/Image.astro';
import IndustryColumnGrid from '~/components/industry/IndustryColumnGrid.astro';

import TabComponent from '~/components/main/TabComponent.astro';
import LogoTabComponent2 from '~/components/main/LogoTabComponent2.astro';
import RelatedPages from '~/components/portfolio/RelatedPages.astro';
import RelatedLinks from '~/components/services/RelatedLinks.astro';
import HighlightedCases from "~/components/services/HighlightedCases.astro";
import Number from '~/components/portfolio/Number.astro';
import ReviewItem from '~/components/portfolio/ReviewItem.astro';
import UniversalSlider from '~/components/common/UniversalSlider.astro'
import Features3 from '~/components/widgets/Features3.astro';
import FeaturesHex from '~/components/widgets/FeaturesHex.astro';
import SimpleSlider from '~/components/services/SimpleSlider.astro';
import SimpleContentSlider from '~/components/services/SimpleContentSlider.astro';

import { Icon } from 'astro-icon/components';
import { SITE } from 'astrowind:config';

import { getPermalink } from '~/utils/permalinks';
import { getEntry } from 'astro:content';

import '~/components/main/Bento.less';

const metadata = {
  canonical: 'https://sobakapav.ru/design-code',
  title: `Собака Павлова • Дизайн сразу в коде`,
  description:
    'Как перестать бояться и полюбить LLM',
  robots: {
    index: true,
    follow: true,
  },
  openGraph: {
    site_name: 'Собака Павлова',
    images: [
      {
        url: '~/assets/images/codedesign.png',
        width: 716,
        height: 600,
      },
    ],
    type: 'article',
  },
};
---

<Layout metadata={metadata}  hasSlider={true}>
  <Bread title="Дизайн сразу в коде" />
  
  <Hero2
      image={{ 
        src: '~/assets/images/design-code.png',
        alt: 'Собака Павлова • Дизайн сразу в коде',
      }}
      imageName='Дизайнеры рассматривают новый инструмент'
      >
    <Fragment slot="title">
      </br>Дизайн</br>сразу в коде
    </Fragment>
    <Fragment slot="subtitle">
      Хотелось написать продающее, но напишем как есть.</br>
      Мы создаём закрытый учебный клуб. И зовём в него тех IT-спецов, кто понимает, что надо браться за AI-технологии, но как-то всё руки не доходят.
    </Fragment>
    <Fragment slot="result">
      <div class="flex flex-row gap-6">
        <div class="text-xl leading-none px-6 py-6 bg-[--aw-color-hund] text-white  flex flex-row align-center mt-2 text-default">
          <a href="https://pay.eduhund.com/codedesign">Сразу купить за 6000 рублей</a>
        </div>
      </div>
    </Fragment>
  </Hero2>
  
  <section class="py-0 mx-auto grow-0 shrink-0">
     <article>
     
  
  
  <div class="flex flex-col max-w-7xl mx-auto px-4 sm:px-6 mb-10 md:mb-0 mt-20">
      <h2 class="text-xl font-heading tracking-widest leading-none text-[--aw-color-hund] mb-6">Как понять, что это для вас?</h2>
      <Features3
        columns={3}
        items={[
        {description: 'Ваша работа связана с интерфейсами.'},
        {description: 'Дизайнер ли вы, менеджер или аналитик — неважно, всех ждем.'},
        {description: 'Программистам будет скучновато, а начинающим — сложновато.'},
        ]}
        classes={{description: 'text-xl', title: ''}}
        defaultIcon="tabler:circle-check-filled"
      />   
    </div>
  
  <div class="flex flex-col sm:flex-row gap-10 max-w-7xl mx-auto px-4 sm:px-6 mb-10 md:mb-10">
    
    <div class="flex flex-col md:flex-row gap-10 md:gap-12 content-start items-start"> 
      <div class="basis-0 grow"> 
        <Image src="~/assets/images/chameleon.png" alt="Собака Павлова • Дизайн сразу в коде" />
         <p class="max-w-3xl mx-auto md:mx-0 lg:mx-auto mt-6 text-base md:text-sm text-muted dark:text-slate-400 text-justify">
            Это хамелеон. Он маскот «Дизайна сразу в коде»
         </p>
      </div>
      <div class="basis-0 grow-[2]"> 
        <p class="text-xl mb-4">Будем учиться, не сходя с рабочего места.</p>
              
        <p class="text-xl mb-4">Не планируем заниматься «прокачкой» и прочими курсами для подготовки к работе. Планируем внедрять AI в вашу уже существующую работу.
        
        <p class="text-xl mb-10">Первая тема для проработки — «UI сразу в коде».</p>
        
        <h2 class="text-xl font-heading tracking-widest leading-none text-[--aw-color-hund] mb-4">UI сразу в коде</h2>
        
        <p class="text-xl mb-4">Что это будет?</p>
        
        <p class="text-xl mb-4">Будет много задач вида «Возьми Figma-компонент — реализуй его в коде».</p>
        
        <p class="text-xl mb-4">Плюс AI-инструмент для их решения. Плюс все, что нужно, чтоб решать их было не больно и не страшно.</p>
      
      </div> 
    </div> 
  </div>
  
  
    
  <div class="flex flex-col max-w-7xl mx-auto px-4 sm:px-6 mb-10 md:mb-10">
    <h2 class="text-xl font-heading tracking-widest leading-none text-[--aw-color-hund] mb-6">Вот что можем обещать</h2>
    <div class="max-w-5xl">
    <IndustryColumnGrid
      columns={2}
      cards={[{title: 'Объяснялки каждый день', text: 'Буквально каждый. Новый день — новая объяснялка. Нет, их пишет не LLM. Некоторые вещи пока просто нельзя поручать машинам.', cardColor: 'blue'},
      {title: 'Задачи для знакомства со сложными темами', text: 'Сюрприз: если хотя бы двое назвали тему сложной — на следующий день под неё появляется набор задач. Живым человеком написанный.', cardColor: 'lightblue'},
      {title: 'Обсуждалки раз в неделю', text: 'Голосом-созвонами. С сотрудниками «Собаки». Может, даже с Павловой, если дело пойдёт бодро.', cardColor: 'lightblue'},
      {title: 'Инструмент для AI-экспериментов', text: 'Настроить поможем. Ваш NDA не пострадает.', cardColor: 'blue'},
      ]}
      classes={{description: 'text-xl', title: ''}}
      defaultIcon="tabler:circle-check-filled"
    /> 
    </div>
  </div>
  
  <div class="flex flex-col sm:flex-row gap-10 max-w-7xl mx-auto px-4 sm:px-6 mb-10 md:mb-10">
      
      <div class="basis-[2] grow gap-6 max-w-5xl">  
        <p class="text-xl mb-4">Может, ещё что-то придумаем.</p>
        <p class="text-xl">Как тут кое-кто у нас любит повторять, «работу работать на свою голову — это мы запросто».</p>
      </div>  
      <div class="basis-0 grow min-w-[260px]">
        
      </div>
    </div>
    
  <div class="flex flex-col max-w-7xl mx-auto px-4 sm:px-6 mb-10 md:mb-10">
    <h2 class="text-xl font-heading tracking-widest leading-none text-[--aw-color-hund] mb-6">А вот что обещать не можем</h2>
    <IndustryColumnGrid
      columns={3}
      cards={[
      {title: 'Мол, всё готово и идеально вылизано', text: 'Если б оно так было, цена была бы как в задачнике.', cardColor: 'black'},
      {title: 'Мол, берём всех', text: 'Тут грустненько. Больше 12 человек пока не потянем.', cardColor: 'grey'},
      {title: 'Мол, в июне будет дороже', text: 'Не-а, в июне вообще может уже не быть.', cardColor: 'black'},
      ]}
      classes={{description: 'text-xl', title: ''}}
      defaultIcon="tabler:circle-check-filled"
    />   
  </div>
  
  <div class="gap-8 max-w-7xl mx-auto px-4 sm:px-6 mb-10 md:mb-10">
    <p class="text-xl mb-4">Что в итоге, если совсем коротко?</p>
          
    <p class="text-xl mb-4 font-bold">Умение поставлять UI-компоненты сразу в коде.</p>
          
    <p class="text-xl mb-4">Стать программистом за месяц — не предлагаем. Невозможно это.</p>
    
    <p class="text-xl mb-6">Предлагаем вот что:</p>
    
    <div class="">
    <IndustryColumnGrid
          columns={3}
          cards={[{title: 'Перестать бояться LLM', cardColor: 'red'}, {title: 'Перестать бояться, что LLM отнимет вашу работу', cardColor: 'red'}]}
      classes={{description: 'text-xl', title: ''}}
      defaultIcon="tabler:circle-check-filled"
    /> 
    </div>
    
  </div>
  
  <div class=" flex flex-col gap-10 max-w-7xl mx-auto px-4 sm:px-6 mb-10 md:mb-12">
    <p class="text-xl mt-6">Детали скоро расскажем. Но сначала о главном: о деньгах.</p>
    <div class="flex flex-col sm:flex-row justify-between gap-10 max-w-5xl">
      <div class="">
        <h3 class="mb-2 text-xl">Цена удовольствия для людей:</h3>
        <Number 
          number="6 тысяч рублей" 
          classes="mb-1.5 font-heading" 
          textClasses="text-xl sm:text-4xl" 
          numberClasses="text-xl sm:text-4xl text-[--aw-color-hund]" 
        />
        <p class="text-xl">За май-июнь (30 дней).</p>
      </div>
      <div class="basis-0 grow">
        <h3 class="mb-2 text-xl">Для компаний по безналу:</h3>
        <Number 
          number="56 тысяч рублей" 
          classes="mb-1.5 font-heading" 
          textClasses="text-xl sm:text-4xl" 
          numberClasses="text-xl sm:text-4xl text-[--aw-color-hund]" 
        />
        <p class="text-xl">Без скидок.</p>
      </div>
    </div>
  </div>

  
  <div class="max-w-7xl mx-auto px-4 sm:px-6">
  <div class="bg-[#212121] p-5 md:p-10 mt-2 mb:mt-8 mb-5 md:mb-10">
    <p class="text-xl mb-4 text-white">Если вас эта сумма не пугает — платите.</p> 
    <p class="text-xl mb-4 text-white">Не понравится — вернём деньги.</p>
    <div class="flex flex-row gap-6">
      <div class="text-xl leading-none px-6 py-6 bg-[--aw-color-hund] text-white  flex flex-row align-center mt-4 text-default">
              <a href="https://pay.eduhund.com/codedesign">Купить за 6000 рублей</a>
            </div>
      
    </div>
    <p class="text-xl text-white mt-6">P.S. К вайбкодингу — никакого отношения.</p>
  </div>
  
</article>
</section>

</Layout>
